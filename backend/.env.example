MONGODB_URI=mongodb://localhost:27017/arc-payment
PORT=5000
NODE_ENV=development

# Arc Blockchain Configuration
ARC_RPC_URL=https://testnet-rpc.arc.io
ARC_TESTNET_RPC_URL=https://testnet-rpc.arc.io
ARC_MAINNET_RPC_URL=https://mainnet-rpc.arc.io

# Smart Contract Addresses (Replace with your deployed addresses)
ARC_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
